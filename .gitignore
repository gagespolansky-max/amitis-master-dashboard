# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# python
/venv
/.venv
__pycache__/
*.py[cod]

# logs and sessions
/logs
/sessions

# Fund Portal runtime artifacts
/data/fund_indexing_log.db
/data/locks/*
!/data/locks/.gitkeep
/data/test-fixtures/*
!/data/test-fixtures/.gitkeep
!/data/test-fixtures/grandline-smoke/
!/data/test-fixtures/grandline-smoke/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
